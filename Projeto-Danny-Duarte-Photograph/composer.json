{
  "name": "danny/site",
  "description": "Site e painel administrativo Danny.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "Danny\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  }
}
